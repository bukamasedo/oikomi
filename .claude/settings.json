{
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(xcodegen *)",
      "Bash(swift build*)",
      "Bash(swift test*)",
      "Bash(swift run*)",
      "Bash(swift package *)",
      "Bash(swift-format *)",
      "Bash(simctl *)",
      "Bash(xcbeautify *)",
      "Bash(brew install xcodegen)",
      "Bash(brew install xcbeautify)",
      "Bash(open Oikomi.xcodeproj)",
      "Bash(open -a Xcode *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-swift.sh"
          }
        ]
      }
    ]
  }
}

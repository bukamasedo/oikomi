      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1RM = weight × (1 + reps / 30)"
          }
        }
      }
    },
    "1RM = weight × 36 / (37 - reps)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1RM = weight × 36 / (37 - reps)"
          }
        }
      }
    },

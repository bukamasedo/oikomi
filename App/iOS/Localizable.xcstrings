    },
    "DEBUG ビルド限定。月・水・金 を Push / Pull / Legs にローテーションした 6 週間分のリアルな履歴を生成し、HealthKit にも HRV / 安静時心拍数 / 睡眠 / 体重 / HKWorkout を書き込みます（権限ダイアログが出ます）。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DEBUG builds only. Generates 6 weeks of realistic history rotating Mon/Wed/Fri through Push / Pull / Legs, and also writes HRV / resting heart rate / sleep / body weight / HKWorkout to HealthKit (a permission dialog will appear)."
          }
        }
      }
    },
    "Deload": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deload"
          }
        }
      }
    },
    "Dynamic Island": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dynamic Island"
          }
        }
      }

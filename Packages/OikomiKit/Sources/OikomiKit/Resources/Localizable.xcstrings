      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : ", "
          }
        }
      }
    },
    "%@ が今週 MEV 未満です。来週は各 +1〜2 セット増やしましょう。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ are below MEV this week. Add 1–2 sets each next week."
          }
        }
      }
    },
    "%@ が回復済みです。次のトレーニング候補です。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ are recovered — good candidates for your next session."
          }
        }
      }
    },
    "%@ は来週 +1〜2 セットで MAV に向けて漸進できます。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ can progress toward MAV with 1–2 more sets next week."
          }
        }
      }
    },
    "%@ 狙い" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Targeting %@"
          }
        }
      }
    },
    "%@はここ%lldセッションほぼ横ばいです。レップ域・頻度・種目の変更を検討してください。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ has been flat for about %2$lld sessions. Consider changing your rep range, frequency, or exercise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@はここ%2$lldセッションほぼ横ばいです。レップ域・頻度・種目の変更を検討してください。"
          }
        }
      }
    },
    "%@は直近2回とも余裕（RPE %lld 以下）でした。次回は %@ → %@ を目安に。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ felt easy (RPE %2$lld or below) the last two times. Next time aim for %3$@ → %4$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@は直近2回とも余裕（RPE %2$lld 以下）でした。次回は %3$@ → %4$@ を目安に。"
          }
        }
      }
    },
    "%@は直近2回とも高強度（RPE %lld 以上）でした。次回は %@ → %@ を目安に。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ was high-intensity (RPE %2$lld+) the last two times. Next time aim for %3$@ → %4$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@は直近2回とも高強度（RPE %2$lld 以上）でした。次回は %3$@ → %4$@ を目安に。"
          }
        }
      }
    },
    "%@を今週から再開しました。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've resumed %@ this week."
